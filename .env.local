# Copy file ini menjadi .env.local untuk development lokal
# Di Vercel, tambahkan variable ini di Settings > Environment Variables

# Daftar user yang boleh akses
# Format: email:kode — pisahkan dengan koma, tanpa spasi
ALLOWED_USERS=admin@gmail.com:admin,

# TIDAK perlu ANTHROPIC_API_KEY — user input API key mereka sendiri di halaman web.
# Server hanya jadi proxy aman: menerima key dari browser, call AI, lalu key langsung dibuang.
# Kamu tidak keluar biaya API sama sekali.
